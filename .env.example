# QuestLog Fluxer Bot - Environment Variables
# Copy to .env for local dev, or set in /etc/casual-heroes/warden.env on server

# Fluxer bot token (required)
FLUXER_BOT_TOKEN=your_fluxer_bot_token_here

# Fluxer API (defaults are correct for production)
FLUXER_API_BASE=https://api.fluxer.app
FLUXER_API_VERSION=1
FLUXER_GATEWAY_URL=wss://gateway.fluxer.app

# Command prefix (default: !)
COMMAND_PREFIX=!

# Environment
ENVIRONMENT=development

# Database (shared with wardenbot)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=warden
DB_PASSWORD=your_db_password_here
DB_NAME=warden
# Or use a Unix socket instead of host/port:
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# Logging
LOG_LEVEL=INFO

# Set to true to echo SQL queries (debug only)
DB_ECHO=false
